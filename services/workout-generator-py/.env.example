# Runtime
WG_APP_ENV=dev
WG_APP_HOST=0.0.0.0
WG_APP_PORT=8091
WG_GRPC_SERVER_HOST=0.0.0.0
WG_GRPC_SERVER_PORT=50052

# OpenAI
WG_OPENAI_API_KEY=sk-...
WG_OPENAI_MODEL=gpt-5-mini
WG_OPENAI_MAX_COMPLETION_TOKENS=8192
WG_OPENAI_TIMEOUT_SECONDS=60

# gRPC integration with Rust backend
WG_GRPC_RUST_HOST=localhost
WG_GRPC_RUST_PORT=50051
WG_GRPC_TIMEOUT_SECONDS=10
