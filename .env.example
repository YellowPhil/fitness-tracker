# ── Shared URLs (single source of truth for all services) ──────────
# FRONTEND_URL: public URL where the frontend (Mini App) is served.
#   Production: https://your-frontend-url.com 
#   Dev:        leave empty when backend serves the SPA (same-origin)
FRONTEND_URL=https://your-frontend-url.com

# BACKEND_URL: public URL where the API is served.
#   Production: https://your-backend-url.com   (Coolify)
#   Dev:        same as FRONTEND_URL or http://localhost:3001
BACKEND_URL=https://your-backend-url.com

# ── Backend ───────────────────────────────────────────────────────
BIND_ADDR=0.0.0.0:3001
GRPC_BIND_ADDR=0.0.0.0:50051
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/fitness_tracker
RUST_LOG=info

# Use RUST_LOG=debug to see application debug spans. Third-party crates (sqlx,
# hyper, reqwest) are capped at warn by default; to include them use e.g.:
RUST_LOG=debug,sqlx=debug

# Optional: required for POST /api/workouts/generate (AI workout plans).
OPENAI_API_KEY=sk-...

# Optional: comma-separated Telegram user IDs allowed to use the app.
# When unset (or empty) every authenticated user is permitted.
ALLOWED_USER_IDS=

# ── Telegram Mini App auth (required in production) ──────────────
# Same token as the bot: used to validate `Authorization: tma <initData>` from the web app.
TELOXIDE_TOKEN=your-telegram-bot-token

# Local dev only: when TELOXIDE_TOKEN is unset, accept `x-user-id` without validation.
# Never set this in production.
# DEV_SKIP_AUTH=1

# ── Bot ───────────────────────────────────────────────────────────
# Uses the same TELOXIDE_TOKEN as above (separate process).

# ── Frontend (baked at build time via Vite) ───────────────────────
# Set VITE_API_BASE to BACKEND_URL when frontend is on a different origin.
# Leave empty when the backend serves the SPA (dev / full-stack mode).
VITE_API_BASE=https://your-backend-url.com

# Local dev only: when not opened inside Telegram, the SPA sends `x-user-id` (needs DEV_SKIP_AUTH=1).
# VITE_DEV_USER_ID=1

# ── Python workout generator service (optional) ─────────────────────
# Separate microservice for AI workout generation flow.
# Keep unset if you are not running the Python service.
# WG_APP_ENV=dev
# WG_APP_HOST=0.0.0.0
# WG_APP_PORT=8091
# WG_OPENAI_API_KEY=sk-...
# WG_OPENAI_MODEL=gpt-5-mini
# WG_OPENAI_MAX_COMPLETION_TOKENS=8192
# WG_OPENAI_TIMEOUT_SECONDS=60
# WG_INTERNAL_BACKEND_BASE_URL=http://localhost:3001
# WG_INTERNAL_TIMEOUT_SECONDS=10
# WG_INTERNAL_EXERCISE_CATALOG_ENDPOINT=/internal/users/{user_id}/exercises
# WG_INTERNAL_WORKOUT_QUERY_ENDPOINT=/internal/users/{user_id}/ai/workout-query
# WG_INTERNAL_EXERCISE_LIST_ENDPOINT=/internal/users/{user_id}/ai/exercise-list
# WG_INTERNAL_AUTH_HEADER_NAME=
# WG_INTERNAL_AUTH_HEADER_VALUE=
